<?xml version="1.0" encoding="UTF-8"?>

<jasperReport xmlns="http://jasperreports.sourceforge.net/jasperreports"
              xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
              xsi:schemaLocation="http://jasperreports.sourceforge.net/jasperreports
              http://jasperreports.sourceforge.net/xsd/jasperreport.xsd"
              name="bi_dashboard_template"
              pageWidth="1200"
              pageHeight="800"
              columnWidth="1160"
              leftMargin="20"
              rightMargin="20"
              topMargin="20"
              bottomMargin="20"
              uuid="11111111-2222-3333-4444-555555555555">

    <!-- ===================== -->
    <!-- PARÂMETROS GLOBAIS    -->
    <!-- ===================== -->

    <parameter name="DATA_INICIAL" class="java.util.Date"/>
    <parameter name="DATA_FINAL" class="java.util.Date"/>
    <parameter name="FILTRO_GLOBAL" class="java.lang.String"/>

    <!-- ===================== -->
    <!-- DATASET PRINCIPAL     -->
    <!-- ===================== -->

    <queryString>
        <![CDATA[

        select
            d.dim1 as dimensao_1,
            d.dim2 as dimensao_2,
            d.ano as ano,
            d.mes as mes,

            sum(d.valor) as valor_total,
            count(distinct d.id) as quantidade

        from fato_dados d

        where d.data between $P{DATA_INICIAL} and $P{DATA_FINAL}

        group by
            d.dim1,
            d.dim2,
            d.ano,
            d.mes

        ]]>
    </queryString>

    <!-- ===================== -->
    <!-- CAMPOS BASE           -->
    <!-- ===================== -->

    <field name="dimensao_1" class="java.lang.String"/>
    <field name="dimensao_2" class="java.lang.String"/>
    <field name="ano" class="java.lang.Integer"/>
    <field name="mes" class="java.lang.Integer"/>
    <field name="valor_total" class="java.lang.Double"/>
    <field name="quantidade" class="java.lang.Long"/>

    <!-- ===================== -->
    <!-- VARIÁVEIS KPIs        -->
    <!-- ===================== -->

    <variable name="TOTAL_VALOR" class="java.lang.Double" calculation="Sum">
        <variableExpression><![CDATA[$F{valor_total}]]></variableExpression>
    </variable>

    <variable name="TOTAL_QTD" class="java.lang.Long" calculation="Sum">
        <variableExpression><![CDATA[$F{quantidade}]]></variableExpression>
    </variable>

    <!-- ===================== -->
    <!-- SUBDATASET 1 - TOP N  -->
    <!-- ===================== -->

    <subDataset name="ds_top_dimensao">

        <queryString>
            <![CDATA[

            select
                d.dim1 as nome,
                sum(d.valor) as valor

            from fato_dados d

            group by d.dim1

            order by valor desc

            ]]>
        </queryString>

        <field name="nome" class="java.lang.String"/>
        <field name="valor" class="java.lang.Double"/>

    </subDataset>

    <!-- ===================== -->
    <!-- SUBDATASET 2 - SERIES -->
    <!-- ===================== -->

    <subDataset name="ds_series_tempo">

        <queryString>
            <![CDATA[

            select
                d.ano as ano,
                d.mes as mes,
                sum(d.valor) as valor

            from fato_dados d

            group by d.ano, d.mes

            order by d.ano, d.mes

            ]]>
        </queryString>

        <field name="ano" class="java.lang.Integer"/>
        <field name="mes" class="java.lang.Integer"/>
        <field name="valor" class="java.lang.Double"/>

    </subDataset>

    <!-- ===================== -->
    <!-- TITLE / HEADER        -->
    <!-- ===================== -->

    <title>
        <band height="120">

            <staticText>
                <reportElement x="0" y="0" width="600" height="30"/>
                <textElement>
                    <font size="20" isBold="true"/>
                </textElement>
                <text><![CDATA[DASHBOARD ANALÍTICO BI]]></text>
            </staticText>

            <textField>
                <reportElement x="0" y="35" width="600" height="20"/>
                <textFieldExpression><![CDATA[
                    "Período: " + $P{DATA_INICIAL} + " até " + $P{DATA_FINAL}
                ]]></textFieldExpression>
            </textField>

            <textField>
                <reportElement x="0" y="55" width="600" height="20"/>
                <textFieldExpression><![CDATA[
                    "Total Geral: " + $V{TOTAL_VALOR}
                ]]></textFieldExpression>
            </textField>

        </band>
    </title>

    <!-- ===================== -->
    <!-- SUMMARY KPIs CARDS    -->
    <!-- ===================== -->

    <summary>
        <band height="150">

            <staticText>
                <reportElement x="0" y="0" width="300" height="20"/>
                <text><![CDATA[KPIs PRINCIPAIS]]></text>
            </staticText>

            <textField>
                <reportElement x="0" y="30" width="300" height="20"/>
                <textFieldExpression><![CDATA["Valor Total: " + $V{TOTAL_VALOR}]]></textFieldExpression>
            </textField>

            <textField>
                <reportElement x="0" y="50" width="300" height="20"/>
                <textFieldExpression><![CDATA["Quantidade: " + $V{TOTAL_QTD}]]></textFieldExpression>
            </textField>

            <!-- ===================== -->
            <!-- GRÁFICO 1 - PIE       -->
            <!-- ===================== -->

            <pieChart>
                <chart>
                    <reportElement x="350" y="0" width="300" height="140"/>
                    <chartTitle>
                        <titleExpression><![CDATA["Distribuição por Dimensão"]]></titleExpression>
                    </chartTitle>
                </chart>

                <pieDataset>

                    <datasetRun subDataset="ds_top_dimensao"/>

                    <keyExpression><![CDATA[$F{nome}]]></keyExpression>
                    <valueExpression><![CDATA[$F{valor}]]></valueExpression>

                </pieDataset>

                <piePlot/>

            </pieChart>

        </band>
    </summary>

    <!-- ===================== -->
    <!-- GRÁFICO 2 - LINE      -->
    <!-- ===================== -->

    <summary>
        <band height="250">

            <timeSeriesChart>
                <chart>
                    <reportElement x="0" y="0" width="700" height="220"/>
                    <chartTitle>
                        <titleExpression><![CDATA["Evolução Temporal"]]></titleExpression>
                    </chartTitle>
                </chart>

                <timeSeriesDataset>

                    <datasetRun subDataset="ds_series_tempo"/>

                    <timePeriodExpression><![CDATA[
                        new java.util.Date($F{ano}, $F{mes}, 1)
                    ]]></timePeriodExpression>

                    <valueExpression><![CDATA[$F{valor}]]></valueExpression>

                </timeSeriesDataset>

                <timeSeriesPlot/>

            </timeSeriesChart>

        </band>
    </summary>

</jasperReport>