<?xml version="1.0" encoding="UTF-8"?>
<jasperReport xmlns="http://jasperreports.sourceforge.net/jasperreports"
              xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
              xsi:schemaLocation="http://jasperreports.sourceforge.net/jasperreports http://jasperreports.sourceforge.net/xsd/jasperreport.xsd"
              name="relatorio_sla_atendimento"
              pageWidth="842"
              pageHeight="595"
              orientation="Landscape"
              columnWidth="802"
              leftMargin="20"
              rightMargin="20"
              topMargin="20"
              bottomMargin="20">

    <style name="Title" fontName="SansSerif" fontSize="20" isBold="true" forecolor="#263238"/>
    <style name="Subtitle" fontName="SansSerif" fontSize="10" forecolor="#546E7A"/>
    <style name="Header" fontName="SansSerif" fontSize="9" isBold="true" forecolor="#FFFFFF" backcolor="#6A1B9A" mode="Opaque"/>
    <style name="Detail" fontName="SansSerif" fontSize="9" forecolor="#212121"/>
    <style name="KpiCard" fontName="SansSerif" fontSize="11" isBold="true" forecolor="#4A148C" backcolor="#F3E5F5" mode="Opaque"/>

    <subDataset name="ds_sla_resumo">
        <field name="dimensao" class="java.lang.String"/>
        <field name="percentualSla" class="java.math.BigDecimal"/>
        <field name="tempoMedioResolucaoHoras" class="java.math.BigDecimal"/>
    </subDataset>

    <parameter name="DATA_INICIAL" class="java.util.Date"/>
    <parameter name="DATA_FINAL" class="java.util.Date"/>
    <parameter name="TITULO_RELATORIO" class="java.lang.String" isForPrompting="false">
        <defaultValueExpression><![CDATA["Dashboard Operacional de SLA"]]></defaultValueExpression>
    </parameter>

    <field name="periodo" class="java.lang.String"/>
    <field name="dimensao" class="java.lang.String"/>
    <field name="tipoFila" class="java.lang.String"/>
    <field name="totalAtendimentos" class="java.lang.Long"/>
    <field name="clientesImpactados" class="java.lang.Long"/>
    <field name="atendimentosDentroSla" class="java.lang.Long"/>
    <field name="atendimentosForaSla" class="java.lang.Long"/>
    <field name="percentualSla" class="java.math.BigDecimal"/>
    <field name="tempoMedioResolucaoHoras" class="java.math.BigDecimal"/>
    <field name="classificacaoSla" class="java.lang.String"/>

    <variable name="TOTAL_ATENDIMENTOS" class="java.lang.Long" calculation="Sum">
        <variableExpression><![CDATA[$F{totalAtendimentos}]]></variableExpression>
    </variable>
    <variable name="TOTAL_DENTRO_SLA" class="java.lang.Long" calculation="Sum">
        <variableExpression><![CDATA[$F{atendimentosDentroSla}]]></variableExpression>
    </variable>
    <variable name="TOTAL_FORA_SLA" class="java.lang.Long" calculation="Sum">
        <variableExpression><![CDATA[$F{atendimentosForaSla}]]></variableExpression>
    </variable>
    <variable name="PERCENTUAL_SLA_GERAL" class="java.lang.Double">
        <variableExpression><![CDATA[
            ($V{TOTAL_ATENDIMENTOS} == null || $V{TOTAL_ATENDIMENTOS}.longValue() == 0L)
            ? 0.0
            : ($V{TOTAL_DENTRO_SLA}.doubleValue() * 100.0) / $V{TOTAL_ATENDIMENTOS}.doubleValue()
        ]]></variableExpression>
    </variable>
    <variable name="MEDIA_TEMPO_GERAL" class="java.math.BigDecimal" calculation="Average">
        <variableExpression><![CDATA[$F{tempoMedioResolucaoHoras}]]></variableExpression>
    </variable>

    <title>
        <band height="78">
            <textField><reportElement style="Title" x="0" y="0" width="520" height="28"/><textFieldExpression><![CDATA[$P{TITULO_RELATORIO}]]></textFieldExpression></textField>
            <textField><reportElement style="Subtitle" x="0" y="32" width="802" height="16"/><textFieldExpression><![CDATA["Período: " + $P{DATA_INICIAL} + " até " + $P{DATA_FINAL}]]></textFieldExpression></textField>
            <staticText><reportElement style="Subtitle" x="0" y="52" width="802" height="16"/><text><![CDATA[Template genérico para filas, SLA, tempo médio e criticidade operacional.]]></text></staticText>
        </band>
    </title>

    <columnHeader>
        <band height="24">
            <staticText><reportElement style="Header" x="0" y="0" width="80" height="22"/><text><![CDATA[Período]]></text></staticText>
            <staticText><reportElement style="Header" x="80" y="0" width="145" height="22"/><text><![CDATA[Fila]]></text></staticText>
            <staticText><reportElement style="Header" x="225" y="0" width="95" height="22"/><text><![CDATA[Tipo]]></text></staticText>
            <staticText><reportElement style="Header" x="320" y="0" width="90" height="22"/><text><![CDATA[Atend.]]></text></staticText>
            <staticText><reportElement style="Header" x="410" y="0" width="90" height="22"/><text><![CDATA[D. SLA]]></text></staticText>
            <staticText><reportElement style="Header" x="500" y="0" width="90" height="22"/><text><![CDATA[F. SLA]]></text></staticText>
            <staticText><reportElement style="Header" x="590" y="0" width="80" height="22"/><text><![CDATA[SLA %]]></text></staticText>
            <staticText><reportElement style="Header" x="670" y="0" width="70" height="22"/><text><![CDATA[Horas]]></text></staticText>
            <staticText><reportElement style="Header" x="740" y="0" width="62" height="22"/><text><![CDATA[Classe]]></text></staticText>
        </band>
    </columnHeader>

    <detail>
        <band height="22">
            <textField><reportElement style="Detail" x="0" y="0" width="80" height="20"/><textFieldExpression><![CDATA[$F{periodo}]]></textFieldExpression></textField>
            <textField><reportElement style="Detail" x="80" y="0" width="145" height="20"/><textFieldExpression><![CDATA[$F{dimensao}]]></textFieldExpression></textField>
            <textField><reportElement style="Detail" x="225" y="0" width="95" height="20"/><textFieldExpression><![CDATA[$F{tipoFila}]]></textFieldExpression></textField>
            <textField><reportElement style="Detail" x="320" y="0" width="90" height="20"/><textFieldExpression><![CDATA[$F{totalAtendimentos}]]></textFieldExpression></textField>
            <textField><reportElement style="Detail" x="410" y="0" width="90" height="20"/><textFieldExpression><![CDATA[$F{atendimentosDentroSla}]]></textFieldExpression></textField>
            <textField><reportElement style="Detail" x="500" y="0" width="90" height="20"/><textFieldExpression><![CDATA[$F{atendimentosForaSla}]]></textFieldExpression></textField>
            <textField pattern="#0.00"><reportElement style="Detail" x="590" y="0" width="80" height="20"/><textFieldExpression><![CDATA[$F{percentualSla}]]></textFieldExpression></textField>
            <textField pattern="#0.00"><reportElement style="Detail" x="670" y="0" width="70" height="20"/><textFieldExpression><![CDATA[$F{tempoMedioResolucaoHoras}]]></textFieldExpression></textField>
            <textField><reportElement style="Detail" x="740" y="0" width="62" height="20"/><textFieldExpression><![CDATA[$F{classificacaoSla}]]></textFieldExpression></textField>
        </band>
    </detail>

    <summary>
        <band height="140">
            <textField><reportElement style="KpiCard" x="0" y="0" width="190" height="28"/><textFieldExpression><![CDATA["Atendimentos: " + $V{TOTAL_ATENDIMENTOS}]]></textFieldExpression></textField>
            <textField><reportElement style="KpiCard" x="200" y="0" width="190" height="28"/><textFieldExpression><![CDATA["Dentro SLA: " + $V{TOTAL_DENTRO_SLA}]]></textFieldExpression></textField>
            <textField><reportElement style="KpiCard" x="400" y="0" width="190" height="28"/><textFieldExpression><![CDATA["Fora SLA: " + $V{TOTAL_FORA_SLA}]]></textFieldExpression></textField>
            <textField><reportElement style="KpiCard" x="600" y="0" width="202" height="28"/><textFieldExpression><![CDATA["SLA geral: " + $V{PERCENTUAL_SLA_GERAL} + "%"]]></textFieldExpression></textField>
            <barChart>
                <chart><reportElement x="0" y="42" width="390" height="90"/><chartTitle><titleExpression><![CDATA["SLA por fila"]]></titleExpression></chartTitle></chart>
                <categoryDataset><categorySeries><seriesExpression><![CDATA["SLA %"]]></seriesExpression><categoryExpression><![CDATA[$F{dimensao}]]></categoryExpression><valueExpression><![CDATA[$F{percentualSla}]]></valueExpression></categorySeries></categoryDataset>
                <barPlot/>
            </barChart>
            <lineChart>
                <chart><reportElement x="410" y="42" width="392" height="90"/><chartTitle><titleExpression><![CDATA["Tempo médio por período"]]></titleExpression></chartTitle></chart>
                <categoryDataset><categorySeries><seriesExpression><![CDATA["Tempo médio"]]></seriesExpression><categoryExpression><![CDATA[$F{periodo}]]></categoryExpression><valueExpression><![CDATA[$F{tempoMedioResolucaoHoras}]]></valueExpression></categorySeries></categoryDataset>
                <linePlot/>
            </lineChart>
        </band>
    </summary>
</jasperReport>
